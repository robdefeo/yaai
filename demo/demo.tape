# yaai demo
Output demo/demo.gif

Set Shell "zsh"
Set FontSize 14
Set Width 1200
Set Height 600
Set Theme "Dracula"
Set Padding 20
Set Framerate 30

# Show the help
Type "cargo run -p yaai -- --help"
Enter
Sleep 3s

# Run a simple prompt
Type `cargo run -p yaai -- -p "What is 1+1" -m "anthropic/claude-haiku-4-5-20251001"`
Enter
Sleep 8s
